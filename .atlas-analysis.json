  "keyFeatures": [
    "JWT-based authentication with role-based access control (RBAC)",
    "Student management: add and list students",
    "Teacher assignment creation with role enforcement",
    "Attendance tracking per student",
    "Assignment submission workflow",
    "Application (leave/request) send and approval flow",
    "Fee/finance management: create and list fees",
    "MongoDB (Mongoose) data persistence"
  ],
  "publicApiSurface": [
    "POST /api/auth/register",
    "POST /api/auth/login",
    "POST /api/student/add",
    "GET /api/student/list",
    "POST /api/teacher/assignment",
    "POST /api/attendance/mark",
    "GET /api/attendance/student/:id",
    "POST /api/assignment/submit",
    "POST /api/application/send",
    "PUT /api/application/approve/:id",
    "POST /api/finance/create",
    "GET /api/finance/list"
  ]
}
